@hostname = localhost
@port = 3000
@host = http://{{hostname}}:{{port}}/api

### Health check
GET http://{{hostname}}:{{port}}/health

### Registro (dispara email de verificación a Mailtrap)
# @name registro
POST {{host}}/user/register
Content-Type: application/json

{
  "email": "user50@example.com",
  "password": "password123",
  "name": "Lino",
  "lastName": "Vives",
  "nif": "12345678X"
}
###
@registro_token = {{registro.response.body.data.accessToken}}

### Validación con código recibido en Mailtrap
@codigo = 614298

PUT {{host}}/user/validation
Authorization: Bearer {{registro_token}}
Content-Type: application/json

{
  "code": "{{codigo}}"
}

### Login
# @name login
POST {{host}}/user/login
Content-Type: application/json

{
  "email": "user1000@example.com",
  "password": "password123"
}
###
@token = {{login.response.body.accessToken}}
@refresh_token = {{login.response.body.refreshToken}}

### Onboarding - datos personales
PUT {{host}}/user/register
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Lino",
  "lastName": "Vives",
  "nif": "12345678X"
}

### Crear compañía
PATCH {{host}}/user/company
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "isFreelance": false,
  "name": "BildyCorp S.L.",
  "cif": "B99999999",
  "address": {
    "street": "Calle Mayor, 15",
    "city": "Castellón"
  }
}

### Subir logo de compañía
PATCH {{host}}/user/logo
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="logo"; filename="test-logo.png"
Content-Type: image/png

< ./uploads/test-logo.png
--boundary--

### Obtener perfil
GET {{host}}/user
Authorization: Bearer {{token}}

### Refresh token
POST {{host}}/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refresh_token}}"
}

### Logout
POST {{host}}/user/logout
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "refreshToken": "{{refresh_token}}"
}

### Cambiar contraseña
PUT {{host}}/user/password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "currentPassword": "password123",
  "newPassword": "nuevaPassword4567"
}

### Invitar compañero
POST {{host}}/user/invite
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "companero@example.com",
  "name": "Invitado",
  "lastName": "Ejemplo"
}

### Soft delete usuario
DELETE {{host}}/user?soft=true
Authorization: Bearer {{token}}

### Hard delete usuario
DELETE {{host}}/user
Authorization: Bearer {{token}}

### Empresa sin nombre - debe dar 400
PATCH {{host}}/user/company
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "isFreelance": false,
  "cif": "B12345678"
}

### Crear cliente
# @name crearCliente
POST {{host}}/client
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "García S.L.",
  "cif": "B12345678",
  "email": "contacto@garcia.com",
  "phone": "612345678",
  "address": {
    "street": "Calle Colón",
    "number": "10",
    "postal": "46001",
    "city": "Valencia",
    "province": "Valencia"
  }
}
###
@clientId = {{crearCliente.response.body.data._id}}

### Listar clientes con paginación
GET {{host}}/client?page=1&limit=10&sort=createdAt
Authorization: Bearer {{token}}

### Buscar cliente por nombre
GET {{host}}/client?name=García
Authorization: Bearer {{token}}

### Obtener cliente por ID
GET {{host}}/client/{{clientId}}
Authorization: Bearer {{token}}

### Actualizar cliente
PUT {{host}}/client/{{clientId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "phone": "699999999",
  "email": "nuevo@garcia.com"
}

### Archivar cliente (soft delete)
DELETE {{host}}/client/{{clientId}}?soft=true
Authorization: Bearer {{token}}

### Listar clientes archivados
GET {{host}}/client/archived
Authorization: Bearer {{token}}

### Restaurar cliente archivado
PATCH {{host}}/client/{{clientId}}/restore
Authorization: Bearer {{token}}

### Eliminar cliente permanentemente
DELETE {{host}}/client/{{clientId}}
Authorization: Bearer {{token}}

### CIF duplicado - debe dar 409
POST {{host}}/client
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Otro cliente",
  "cif": "B12345678"
}

### Crear proyecto
# @name crearProyecto
POST {{host}}/project
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Reforma Oficina Central",
  "projectCode": "PRJ-001",
  "client": "{{clientId}}",
  "email": "proyecto@garcia.com",
  "address": {
    "street": "Av. del Puerto",
    "number": "5",
    "postal": "46024",
    "city": "Valencia",
    "province": "Valencia"
  },
  "notes": "Reforma completa de la planta baja",
  "active": true
}
###
@projectId = {{crearProyecto.response.body.data._id}}

### Listar proyectos con paginación
GET {{host}}/project?page=1&limit=10&active=true&sort=-createdAt
Authorization: Bearer {{token}}

### Filtrar proyectos por cliente
GET {{host}}/project?client={{clientId}}
Authorization: Bearer {{token}}

### Obtener proyecto por ID
GET {{host}}/project/{{projectId}}
Authorization: Bearer {{token}}

### Actualizar proyecto
PUT {{host}}/project/{{projectId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "notes": "Notas actualizadas",
  "active": false
}

### Archivar proyecto (soft delete)
DELETE {{host}}/project/{{projectId}}?soft=true
Authorization: Bearer {{token}}

### Listar proyectos archivados
GET {{host}}/project/archived
Authorization: Bearer {{token}}

### Restaurar proyecto archivado
PATCH {{host}}/project/{{projectId}}/restore
Authorization: Bearer {{token}}

### Eliminar proyecto permanentemente
DELETE {{host}}/project/{{projectId}}
Authorization: Bearer {{token}}

### Código de proyecto duplicado - debe dar 409
POST {{host}}/project
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Otro proyecto",
  "projectCode": "PRJ-001",
  "client": "{{clientId}}"
}

### Crear albarán de horas
# @name crearAlbaranHoras
POST {{host}}/deliverynote
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "client": "{{clientId}}",
  "format": "hours",
  "description": "Instalación eléctrica planta baja",
  "workDate": "2025-05-01",
  "hours": 8,
  "workers": [
    { "name": "Carlos López", "hours": 5 },
    { "name": "Ana Martínez", "hours": 3 }
  ]
}
###
@noteHorasId = {{crearAlbaranHoras.response.body.data._id}}

### Crear albarán de materiales
# @name crearAlbaranMaterial
POST {{host}}/deliverynote
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "client": "{{clientId}}",
  "format": "material",
  "description": "Suministro de cable eléctrico",
  "workDate": "2025-05-02",
  "material": "Cable UTP Cat6",
  "quantity": 100,
  "unit": "metros"
}
###
@noteMaterialId = {{crearAlbaranMaterial.response.body.data._id}}

### Listar albaranes con paginación
GET {{host}}/deliverynote?page=1&limit=10&sort=-workDate
Authorization: Bearer {{token}}

### Filtrar albaranes por formato
GET {{host}}/deliverynote?format=hours
Authorization: Bearer {{token}}

### Filtrar albaranes por proyecto
GET {{host}}/deliverynote?project={{projectId}}
Authorization: Bearer {{token}}

### Filtrar albaranes por rango de fechas
GET {{host}}/deliverynote?from=2025-01-01&to=2025-12-31
Authorization: Bearer {{token}}

### Filtrar albaranes firmados
GET {{host}}/deliverynote?signed=true
Authorization: Bearer {{token}}

### Obtener albarán por ID (con populate de user, client, project)
GET {{host}}/deliverynote/{{noteHorasId}}
Authorization: Bearer {{token}}

### PDF sin firmar (genera al vuelo con pdfkit)
GET {{host}}/deliverynote/pdf/{{noteMaterialId}}
Authorization: Bearer {{token}}

### Firmar albarán (Sharp + Cloudinary + genera PDF)
PATCH {{host}}/deliverynote/{{noteHorasId}}/sign
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="signature"; filename="firma.png"
Content-Type: image/png

< ./uploads/test-logo.png
--boundary--

### PDF firmado (redirige a Cloudinary)
GET {{host}}/deliverynote/pdf/{{noteHorasId}}
Authorization: Bearer {{token}}

### Eliminar albarán no firmado
DELETE {{host}}/deliverynote/{{noteMaterialId}}
Authorization: Bearer {{token}}

### Eliminar albarán firmado - debe dar 400
DELETE {{host}}/deliverynote/{{noteHorasId}}
Authorization: Bearer {{token}}
